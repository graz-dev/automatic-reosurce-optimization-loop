{
  "uid": "petclinic-optimizer",
  "title": "PetClinic \u2014 Optimizer Validation",
  "description": "Validates optimizer recommendations: load test throughput, CPU/memory actual vs limits, JVM heap/off-heap.",
  "tags": [
    "petclinic",
    "optimizer",
    "jvm"
  ],
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "graphTooltip": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "\ud83c\udf0a Load Test \u2014 HTTP",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Throughput (req/s)",
      "description": "Request rate from K6 via OTel. If flat \u2192 load test not running.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(petclinic_http_server_request_duration_seconds_count{job=~\"$job\"}[1m]))",
          "legendFormat": "req/s",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Latency \u2014 p50 / p95 / p99",
      "description": "Response time percentiles. p99 spike \u2192 CPU throttling or memory pressure.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le)(rate(petclinic_http_server_request_duration_seconds_bucket{job=~\"$job\"}[1m])))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le)(rate(petclinic_http_server_request_duration_seconds_bucket{job=~\"$job\"}[1m])))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le)(rate(petclinic_http_server_request_duration_seconds_bucket{job=~\"$job\"}[1m])))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "\u2699\ufe0f CPU \u2014 Actual vs Optimizer Recommendation",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Usage vs Request vs Limit",
      "description": "Solid = actual. Dashed = request. Red dashed = limit. Limit should be close to actual; large gap = over-provisioned (what the optimizer corrects).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "cores",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    4
                  ],
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "C"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    4
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"$pod_prefix.*\", container!=\"\", container!=\"POD\"}[1m]))",
          "legendFormat": "Used",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        },
        {
          "expr": "sum(kube_pod_container_resource_requests{pod=~\"$pod_prefix.*\", resource=\"cpu\", container!=\"\"})",
          "legendFormat": "Request",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "B"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{pod=~\"$pod_prefix.*\", resource=\"cpu\", container!=\"\"})",
          "legendFormat": "Limit",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Throttling %",
      "description": "% of CFS periods throttled. >10% (yellow) = limit too tight, latency will spike.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_cfs_throttled_periods_total{pod=~\"$pod_prefix.*\", container!=\"\", container!=\"POD\"}[1m])) / sum(rate(container_cpu_cfs_periods_total{pod=~\"$pod_prefix.*\", container!=\"\", container!=\"POD\"}[1m]))",
          "legendFormat": "Throttle %",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "\ud83d\udcbe Memory \u2014 Actual vs Optimizer Recommendation",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Container Memory (working set) vs Request vs Limit",
      "description": "Solid = actual working set. Dashed = request. Red dashed = limit. Optimizer sizes limit = (heap+off-heap)\u00d7headroom.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    4
                  ],
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "C"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    4
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{pod=~\"$pod_prefix.*\", container!=\"\", container!=\"POD\"})",
          "legendFormat": "Working Set",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        },
        {
          "expr": "sum(kube_pod_container_resource_requests{pod=~\"$pod_prefix.*\", resource=\"memory\", container!=\"\"})",
          "legendFormat": "Request",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "B"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{pod=~\"$pod_prefix.*\", resource=\"memory\", container!=\"\"})",
          "legendFormat": "Limit",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "C"
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "\u2615 JVM \u2014 Heap / Off-heap / -Xmx (what the optimizer measures)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "JVM Heap Used vs -Xmx cap",
      "description": "Optimizer sets -Xmx = heap_observed \u00d7 headroom. If heap approaches Xmx \u2192 GC pressure. Large gap \u2192 -Xmx over-provisioned.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by(host_name)(petclinic_jvm_memory_used_bytes{job=~\"$job\", jvm_memory_type=\"heap\", host_name=~\"$pod\"})",
          "legendFormat": "Heap Used \u2014 {{host_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum by(host_name)(petclinic_jvm_memory_limit_bytes{job=~\"$job\", jvm_memory_type=\"heap\", host_name=~\"$pod\"})",
          "legendFormat": "-Xmx cap \u2014 {{host_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "JVM Off-heap (Metaspace + Code Cache)",
      "description": "Off-heap is added to heap to size the container memory limit. Optimizer: container_limit = (heap + off-heap) \u00d7 headroom.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by(host_name)(petclinic_jvm_memory_used_bytes{job=~\"$job\", jvm_memory_type=\"non_heap\", host_name=~\"$pod\"})",
          "legendFormat": "Off-heap \u2014 {{host_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "GC Stop-the-World Time %",
      "description": "Fraction of time spent in STW GC pauses. >5% \u2192 heap too small (-Xmx needs raising).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by(host_name)(rate(petclinic_jvm_gc_duration_seconds_sum{job=~\"$job\", host_name=~\"$pod\"}[1m]))",
          "legendFormat": "GC time % \u2014 {{host_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "JVM Process CPU (cores)",
      "description": "CPU consumed by the JVM process alone (from jvm_cpu_time). Should track container CPU usage closely.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "fillOpacity": 8
          },
          "unit": "cores",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by(host_name)(rate(petclinic_jvm_cpu_time_seconds_total{job=~\"$job\", host_name=~\"$pod\"}[1m]))",
          "legendFormat": "JVM CPU \u2014 {{host_name}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "custom",
        "current": {
          "text": "otel-collector",
          "value": "otel-collector"
        },
        "options": [
          {
            "selected": true,
            "text": "otel-collector",
            "value": "otel-collector"
          }
        ],
        "query": "otel-collector",
        "hide": 0
      },
      {
        "name": "pod_prefix",
        "label": "Pod prefix",
        "type": "textbox",
        "current": {
          "text": "petclinic",
          "value": "petclinic"
        },
        "query": "petclinic",
        "hide": 0
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(petclinic_jvm_memory_used_bytes{job=~\"$job\"}, host_name)",
        "query": {
          "query": "label_values(petclinic_jvm_memory_used_bytes{job=~\"$job\"}, host_name)",
          "refId": "StandardVariableQuery"
        },
        "allValue": ".*",
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  }
}